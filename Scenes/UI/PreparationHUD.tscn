[gd_scene format=3]

[ext_resource type="Script" path="res://Scripts/UI/PreparationHUD.gd" id="1_hud"]

[node name="PreparationHUD" type="CanvasLayer" node_paths=PackedStringArray("timer_label", "primary_weapon_label", "secondary_weapon_label", "warning_label")]
script = ExtResource("1_hud")
timer_label = NodePath("MarginContainer/VBoxContainer/TimerLabel")
primary_weapon_label = NodePath("MarginContainer/VBoxContainer/PrimaryWeaponLabel")
secondary_weapon_label = NodePath("MarginContainer/VBoxContainer/SecondaryWeaponLabel")
warning_label = NodePath("WarningLabel")

[node name="MarginContainer" type="MarginContainer" parent="."]
offset_right = 280.0
offset_bottom = 140.0
theme_override_constants/margin_left = 20
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 20
theme_override_constants/margin_bottom = 20

[node name="VBoxContainer" type="VBoxContainer" parent="MarginContainer"]
layout_mode = 2

[node name="TimerLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 32
text = "01:00"

[node name="PrimaryWeaponLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
text = "Activa: Vacía"

[node name="SecondaryWeaponLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
text = "Secundaria: Vacía"

[node name="WarningLabel" type="Label" parent="."]
anchors_preset = 10
anchor_right = 1.0
offset_bottom = 70.0
grow_horizontal = 2
theme_override_colors/font_color = Color(1, 0.2, 0.1, 1)
theme_override_font_sizes/font_size = 28
text = "¡QUEDA POCO TIEMPO!"
horizontal_alignment = 1
